# Kopiere diese Datei zu "secrets.env" und trage eure Werte ein.
# secrets.env wird NICHT zu GitHub hochgeladen (steht in .gitignore).

# --- Meta: EINMALIGE Einrichtung (nur diese 3 ausfuellen, dann meta-bootstrap.js laufen lassen) ---
META_APP_ID=
META_APP_SECRET=
META_USER_TOKEN_SHORT=
# Optional, falls mehrere Facebook-Seiten: Index der richtigen Seite (0,1,2,...)
# META_PAGE_PICK=0

# --- Meta: werden von meta-bootstrap.js automatisch befuellt (leer lassen) ---
META_PAGE_ID=
META_PAGE_TOKEN=
META_IG_USER_ID=
META_GRAPH_VERSION=v21.0

# --- X (Twitter) ---
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# --- Oeffentliche Basis-URL, unter der das Tagesbild liegt (wird spaeter gesetzt) ---
PUBLIC_IMAGE_BASE=
